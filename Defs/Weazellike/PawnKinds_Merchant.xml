<?xml version="1.0" encoding="utf-8" ?>
<Defs>
    <!--위젤 물류담당관-->
    <PawnKindDef ParentName="WeazelBasePawnKind">
        <defName>Weazel_Merchant</defName>
        <label>위젤 물류담당관</label>
        <combatPower>14</combatPower>
        <isFighter>true</isFighter>
        <forceNormalGearQuality>true</forceNormalGearQuality>
        <apparelIgnoreSeasons>false</apparelIgnoreSeasons>
        <trader>true</trader>
        <backstoryFiltersOverride>
			<li>
				<categories>
					<li>WeazelRecruitAble</li> <!-- 백스토리 추후 수정 요망 -->
				</categories>
			</li>
		</backstoryFiltersOverride>
        <apparelTags>
            <li>Weazel_Infantry</li>
		</apparelTags>
        <apparelMoney>
			<min>290</min>
			<max>310</max>
		</apparelMoney>
        <apparelRequired>
            <li>Weazel_Bodysuit_A</li>
		</apparelRequired>
        <weaponTags>
            <li>W_Recruit</li>
		</weaponTags>
        <weaponMoney>
			<min>135</min>
			<max>400</max>
		</weaponMoney>
        <techHediffsChance>0.0</techHediffsChance>
        <apparelAllowHeadgearChance>0.0</apparelAllowHeadgearChance>
        <inventoryOptions>
			<skipChance>0.5</skipChance>
			<subOptionsChooseOne>
				<li>
					<thingDef>Weazel_Essence</thingDef>
					<countRange>
						<min>1</min>
						<max>2</max>
					</countRange>
				</li>
			</subOptionsChooseOne>
		</inventoryOptions>
        <initialWillRange>0~1</initialWillRange>
        <initialResistanceRange>10~15</initialResistanceRange>
    </PawnKindDef>

