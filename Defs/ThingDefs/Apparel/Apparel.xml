    <!--위젤 마르더 파워헬멧-->
    <ThingDef ParentName="Weazel_MachineableGearBase">
        <defName>Weazel_MarderHelmat</defName>
        <description>군용 헬맷보단 높지만 타 파워 아머의 헬맷에 비해 낮은 방어력을 가진 헬맷입니다. \n\n클론 종족인 위젤은 물질적인 가치보다 더 집착하는 것이 '개성'입니다. 종족 구성 전체가 똑같이 사고하고 똑같이 생겼다는 것은 대부분의 위젤이 다르게 보이는 것에 집착하게 만들었습니다.\n덕분에 파워 아머를 얻은 위젤이 가장 먼저 하는 것은 헬맷에 자신의 '개성'을 상징하는 것을 장식하는 것 입니다.\n\n하지만 생각하는 것이 비슷하다는 클론의 한계 상 결국 헬맷에 표현한 그 개성도 비슷한 모습인 경우가 흔합니다.</description>
        <label>Weazel Marder Helmat</label>
        <recipeMaker>
            
        </recipeMaker>
        <graphicData>
            <texPath>Weazellike/Apparel/Armor/MarderHelmat</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <costList>
            <Plasteel>40</Plasteel>
            <ComponentIndustrial>1</ComponentIndustrial>
        </costList>
        <statBases>
            <MarketValue>635</MarketValue>
            <MaxHitPoints>160</MaxHitPoints>
            <WorkToMake>21000</WorkToMake>
            <Mass>2.7</Mass>
            <Flammability>0.4</Flammability>
            <ArmorRating_Sharp>0.88</ArmorRating_Sharp>
            <ArmorRating_Blunt>0.45</ArmorRating_Blunt>
            <ArmorRating_Heat>0.54</ArmorRating_Heat>
            <Insulation_Cold>4.0</Insulation_Cold>
            <Insulation_Heat>2.0</Insulation_Heat>
            <EquipDelay>4</EquipDelay>
        </statBases>
        <equippedStatOffsets>
            <AimingDelayFactor>-0.05</AimingDelayFactor>
            <VacuumResistance MayRequire="Ludeon.RimWorld.Odyssey">0.68</VacuumResistance>
        </equippedStatOffsets>
        <apparel>
            <immuneToToxGasExposure>true</immuneToToxGasExposure>
            <bodyPartGroups>
                <li>FullHead</li>
                <li>UpperHead</li>
                <li>Ears</li>
            </bodyPartGroups>          
            <wornGraphicPath>Weazellike/Apparel/Armor/MarderHelmat</wornGraphicPath>
            <drawData>
                <defaultData>
                    <offset>(0.0,1.0,-0.22)</offset>
                </defaultData>
                <dataSouth>
                    <offset>(0.0,1.0,-0.25)</offset>
                </dataSouth>
                <dataNorth>
                    <offset>(0.0,1.0,-0.27)</offset>
                </dataNorth>
                <dataEast>
                    <offset>(0.0,1.0,-0.22)</offset>
                </dataEast>
            </drawData>
            <layers>
                <li>Overhead</li>
            </layers>
            <defaultOutfitTags>
                <li>Soldier</li>
            </defaultOutfitTags>
        </apparel>
    </ThingDef>

