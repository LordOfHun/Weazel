<Defs>
    <ThingCategoryDef>
        <defName>WeazelApparel</defName>
        <label>Weazel Apparel</label>
        <parent>Apparel</parent>
    </ThingCategoryDef>

    <ThingCategoryDef>
        <defName>WeazelHeadgear</defName>
        <label>Weazel Headgear</label>
        <parent>WeazelApparel</parent>
    </ThingCategoryDef>

    <ThingCategoryDef>
        <defName>WeazelCombatgear</defName>
        <label>Weazel Combatgear</label>
        <parent>WeazelApparel</parent>
    </ThingCategoryDef>

    <!--Apparelbase-->
    <ThingDef Name="Weazel_ApparelBase" Abstract="True">
        <thingClass>Apparel</thingClass>
        <category>Item</category>
        <selectable>True</selectable>
        <pathCost>10</pathCost>
        <useHitPoints>True</useHitPoints>
        <techLevel>Industrial</techLevel>
        <graphicData>
            <onGroundRandomRotateAngle>35</onGroundRandomRotateAngle>
            <drawSize>1</drawSize>
        </graphicData>
        <drawGUIOverlay>true</drawGUIOverlay>
        <tradeability>Sellable</tradeability>
        <statBases>
            <MaxHitPoints>100</MaxHitPoints>
            <Flammability>1.0</Flammability>
            <DeteriorationRate>2</DeteriorationRate>
            <Beauty>2</Beauty>
        </statBases>
        <altitudeLayer>Item</altitudeLayer>
        <alwaysHaulable>True</alwaysHaulable>
        <tickerType>Never</tickerType>
        <comps>
            <li Class="CompProperties_Forbiddable"/>
            <li>
                <compClass>CompQuality</compClass>
            </li>
            <li>
                <compClass>CompColorable</compClass>
            </li>
        </comps>
        <apparel>
            <developmentalStageFilter>Child, Adult</developmentalStageFilter>
            <tags>
                <li>Weazel_Apparel</li>
                <li>Weazel_Infantry</li>
            </tags>
        </apparel>
        <recipeMaker>
            <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
            <workSkill>Crafting</workSkill>
            <effectWorking>Tailor</effectWorking>
            <soundWorking>Recipe_Tailor</soundWorking>
            <researchPrerequisite>WeazelEssenceWeaver</researchPrerequisite>
            <recipeUsers>
                <li>HandTailoringBench</li>
                <li>ElectricTailoringBench</li>
            </recipeUsers>
            <unfinishedThingDef>UnfinishedApparel</unfinishedThingDef>
        </recipeMaker>
        <thingCategories>
            <li>WeazelApparel</li>
        </thingCategories>
        <tradeTags>
            <li>Clothing</li>
        </tradeTags>
    </ThingDef>

    <ThingDef Name="Weazel_HatMakeableBase" ParentName="Weazel_ApparelBase" Abstract="True">
        <thingCategories Inherit="False">
            <li>WeazelHeadgear</li>
        </thingCategories>
    </ThingDef>

    <!--Gearbase-->
    <ThingDef Name="Weazel_MachineableGearBase" Abstract="True">
        <thingClass>Apparel</thingClass>
        <category>Item</category>
        <selectable>True</selectable>
        <pathCost>10</pathCost>
        <useHitPoints>True</useHitPoints>
        <techLevel>Industrial</techLevel>
        <graphicData>
            <onGroundRandomRotateAngle>35</onGroundRandomRotateAngle>
        </graphicData>
        <drawGUIOverlay>true</drawGUIOverlay>
        <tradeability>Sellable</tradeability>
        <statBases>
            <MaxHitPoints>100</MaxHitPoints>
            <Flammability>1.0</Flammability>
            <DeteriorationRate>2</DeteriorationRate>
            <Beauty>0</Beauty>
        </statBases>
        <altitudeLayer>Item</altitudeLayer>
        <alwaysHaulable>True</alwaysHaulable>
        <tickerType>Never</tickerType>
        <comps>
            <li Class="CompProperties_Forbiddable"/>
            <li>
                <compClass>CompColorable</compClass>
            </li>
            <li>
                <compClass>CompQuality</compClass>
            </li>
        </comps>
        <apparel>
            <developmentalStageFilter>Child, Adult</developmentalStageFilter>
            <tags>
                <li>Weazel_Apparel</li>
            </tags>
            <defaultOutfitTags>
                <li>Soldier</li>
            </defaultOutfitTags>
        </apparel>
        <recipeMaker>
            <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
            <workSkill>Crafting</workSkill>
            <effectWorking>Smith</effectWorking>
            <soundWorking>Recipe_Machining</soundWorking>
            <researchPrerequisite>WeazelPowerArmor</researchPrerequisite>
            <recipeUsers>
                <li>FabricationBench</li>
            </recipeUsers>
            <unfinishedThingDef>UnfinishedArmor</unfinishedThingDef>
            <defaultIngredientFilter>
                <categories>
                    <li>Root</li>
                </categories>
            </defaultIngredientFilter>
        </recipeMaker>
        <colorGenerator Class="ColorGenerator_Options">
            <options>
                <li>
                    <weight>10</weight>
                    <only>(1,1,1,1)</only>
                </li>
            </options>
        </colorGenerator>
        <thingCategories>
            <li>WeazelApparel</li>
            <li>WeazelCombatgear</li>
        </thingCategories>
        <tradeTags>
            <li>Clothing</li>
            <li>Armor</li>
        </tradeTags>
    </ThingDef>
    <ThingDef Name="Weazel_MachineableHeadGearBase" ParentName="Weazel_MachineableGearBase" Abstract="True">
        <thingCategories Inherit="False">
            <li>WeazelHeadgear</li>
        </thingCategories>
    </ThingDef>

