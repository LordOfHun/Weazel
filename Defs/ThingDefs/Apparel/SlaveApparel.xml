<?xml version="1.0" encoding="utf-8" ?>
<Defs>
    <!-- 위젤 바디슈트 (간수복) -->
    <ThingDef ParentName="Weazel_ApparelBase">
        <defName>Weazel_Bodysuit_Warder</defName>
        <description>위젤 간수들이 착용하는 바디슈트입니다.</description>
        <label>위젤 간수 바디슈트</label>
        <recipeMaker>
            
        </recipeMaker>
        <graphicData>
            <texPath>Weazellike/Apparel/WeazelBodysuitW</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <costList>
            <Weazel_EssentialSilk>65</Weazel_EssentialSilk>
        </costList>
        <statBases>
            <MarketValue>290</MarketValue>
            <MaxHitPoints>130</MaxHitPoints>
            <WorkToMake>2700</WorkToMake>
            <Mass>2.2</Mass>
            <Flammability>0.6</Flammability>
            <ArmorRating_Sharp>0.28</ArmorRating_Sharp>
            <ArmorRating_Blunt>0.07</ArmorRating_Blunt>
            <ArmorRating_Heat>0.6</ArmorRating_Heat>
            <Insulation_Cold>14.4</Insulation_Cold>
            <Insulation_Heat>3</Insulation_Heat>
            <EquipDelay>4</EquipDelay>
        </statBases>
        <equippedStatOffsets>
            <VacuumResistance MayRequire="Ludeon.RimWorld.Odyssey">0.02</VacuumResistance>
            <SuppressionPower MayRequire="Ludeon.RimWorld.Ideology">0.2</SuppressionPower>
        </equippedStatOffsets>
        <apparel>
            <bodyPartGroups>
                <li>Torso</li>
                <li>Neck</li>
                <li>Shoulders</li>
                <li>Arms</li>
                <li>Legs</li>
            </bodyPartGroups>
            <wornGraphicPath>Weazellike/Apparel/WeazelBodysuitW</wornGraphicPath>
            <drawData>
                <defaultData>
                    <offset>(0,0.001,0.08)</offset>
                </defaultData>
            </drawData>
            <layers>
                <li>OnSkin</li>
            </layers>
            <defaultOutfitTags>
                <li>Soldier</li>
            </defaultOutfitTags>
        </apparel>
    </ThingDef>
    
    <ThingDef ParentName="Weazel_ApparelBase">
        <defName>Weazel_Wardenhat</defName>
        <description>위젤의 간수가 착용하는 간수모입니다.</description>
        <label>위젤 간수모</label>
        <techLevel>Spacer</techLevel>
        <recipeMaker>

        </recipeMaker>
        <graphicData>
            <texPath>Weazellike/Apparel/WeazelWardenHat</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <costList>
            <Weazel_EssentialSilk>35</Weazel_EssentialSilk>
        </costList>
        <statBases>
            <MaxHitPoints>150</MaxHitPoints>
            <WorkToMake>6000</WorkToMake>
            <Mass>1.2</Mass>
            <Flammability>0.7</Flammability>
            <ArmorRating_Sharp>0.38</ArmorRating_Sharp>
            <ArmorRating_Blunt>0.10</ArmorRating_Blunt>
            <ArmorRating_Heat>0.36</ArmorRating_Heat>
            <Insulation_Cold>8.14</Insulation_Cold>
            <Insulation_Heat>7.70</Insulation_Heat>
            <EquipDelay>1</EquipDelay>
        </statBases>
        <equippedStatOffsets>
            <MentalBreakThreshold>-0.06</MentalBreakThreshold>
            <NegotiationAbility>0.1</NegotiationAbility>
            <SocialImpact>0.1</SocialImpact>
            <SuppressionPower MayRequire="Ludeon.RimWorld.Ideology">0.1</SuppressionPower>
        </equippedStatOffsets>
        <apparel>
            <bodyPartGroups>
                <li>UpperHead</li>
            </bodyPartGroups>
            <wornGraphicPath>Weazellike/Apparel/WeazelWardenHat</wornGraphicPath>
            <layers>
                <li>Overhead</li>
            </layers>
            <defaultOutfitTags>
                <li>Worker</li>
                <li>Soldier</li>
            </defaultOutfitTags>
            <tags>
                <li>RBC_Elite</li>
                <li>RoyalTier5</li>
            </tags>
        </apparel>
    </ThingDef>
    
    <ThingDef ParentName="ApparelMakeableBase" MayRequire="Ludeon.RimWorld.Ideology">
        <defName>Weazel_Slavesuit</defName>
        <label>위젤 에센스 노예복</label>
        <description>위젤의 노하우로 제작된 특수 노예복입니다.\n노예의 노동력에 영향력을 주지않는 선에서 최대의 에센스를 자동으로 추출해냅니다.</description>
        <graphicData>
            <texPath>Weazellike/Apparel/W_Slaveoutfit/Wslaveoutfit</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <shaderType>CutoutComplex</shaderType>
        </graphicData>
        <recipeMaker>
            <researchPrerequisite>ComplexClothing</researchPrerequisite>
            <researchPrerequisite>WeazelWeazelSlavesuit</researchPrerequisite>
        </recipeMaker>
        <stuffCategories>
            <li>Fabric</li>
            <li>Leathery</li>
        </stuffCategories>
        <costStuffCount>60</costStuffCount>
        <costList>
            <ComponentIndustrial>1</ComponentIndustrial>
        </costList>
        <statBases>
            <MaxHitPoints>100</MaxHitPoints>
            <WorkToMake>1600</WorkToMake>
            <Mass>0.75</Mass>
            <StuffEffectMultiplierArmor>0.2</StuffEffectMultiplierArmor>
            <StuffEffectMultiplierInsulation_Cold>0.55</StuffEffectMultiplierInsulation_Cold>
            <StuffEffectMultiplierInsulation_Heat>0.55</StuffEffectMultiplierInsulation_Heat>
            <EquipDelay>1.5</EquipDelay>
        </statBases>
        <equippedStatOffsets>
            <SlaveSuppressionOffset>0.15</SlaveSuppressionOffset>
            <WorkSpeedGlobal>0.15</WorkSpeedGlobal>
        </equippedStatOffsets>
        <apparel>
            <bodyPartGroups>
                <li>Torso</li>
            </bodyPartGroups>
            <wornGraphicPath>Weazellike/Apparel/W_Slaveoutfit/Wslaveoutfit</wornGraphicPath>
            <useWornGraphicMask>true</useWornGraphicMask>
            <layers>
                <li>OnSkin</li>
            </layers>
            <defaultOutfitTags>
                <li>Slave</li>
            </defaultOutfitTags>
            <tags>
                <li>Weazel_Slave</li>
            </tags>
        </apparel>
        <colorGenerator Class="ColorGenerator_StandardApparel"/>
        <comps>
            <li Class="CompProperties_CauseHediff_Apparel">
                <hediff>Weazel_Slavesuit</hediff>
                <part>Torso</part>
            </li>
        </comps>
    </ThingDef>

    <HediffDef>
        <defName>Weazel_Slavesuit</defName>
        <label>에센스 추출</label>
        <description>신체에 부담이 가지않는 선에서 지속적인 에센스 추출을 당하고있습니다.</description>
        <hediffClass>HediffWithComps</hediffClass>
        <stages>

        </stages>
        <comps>
            <li Class="HediffCompProperties_RemoveIfApparelDropped" />
            <li Class="WeazelDrop.HediffCompProperties_DropItem">
                <tickInterval>60000</tickInterval> <!-- 약 1시간 -->
                <thingDef>Weazel_Essence</thingDef> <!-- 떨어뜨릴 아이템 -->
                <count>15</count>
            </li>
        </comps>
        <isBad>false</isBad>
    </HediffDef>
</Defs>