<?xml version="1.0" encoding="utf-8" ?>
<Defs>
    <ThingDef ParentName="MakeableDrugBase">
        <defName>Weazel_EssenceSmokeleaf</defName>
        <label>에센스 블로</label>
        <description>에센스 연기를 흡인할 수 있게 만든 연초입니다.</description>
        <descriptionHyperlinks>
            <HediffDef>EssenceSmokeleafHigh</HediffDef>
            <HediffDef>EssenceSmokeleafTolerance</HediffDef>
            <HediffDef>EssenceSmokeleafAddiction</HediffDef>
        </descriptionHyperlinks>
        <graphicData>
        <texPath>Things/Drug/EssenceSmokeleaf</texPath>
        <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <rotatable>false</rotatable>
        <statBases>
        <WorkToMake>450</WorkToMake>
        <MarketValue>13</MarketValue>
        <Mass>0.05</Mass>
        <Flammability>1.3</Flammability>
        </statBases>
        <!--<techLevel>Industrial</techLevel>-->
        <ingestible>
            <foodType>Plant, Processed</foodType>
            <joyKind>Chemical</joyKind>
            <joy>0.60</joy>
            <baseIngestTicks>720</baseIngestTicks>
            <nurseable>true</nurseable>
            <drugCategory>Social</drugCategory>
            <foodType>Processed, Fluid</foodType>
            <ingestSound>Ingest_Inject</ingestSound>
            <ingestSound>Ingest_Smoke</ingestSound>
        <ingestEffect>Smoke_Joint</ingestEffect>
        <ingestEffectEat>EatVegetarian</ingestEffectEat>
            <ingestHoldOffsetStanding>
                <northDefault>
                    <offset>(0.27,0,0.08)</offset>
                    <behind>true</behind>
                </northDefault>
                <east>
                    <offset>(0.45,0,0.08)</offset>
                </east>
                <south>
                    <offset>(0.27,0,0.08)</offset>
                </south>
                <west>
                    <offset>(-0.50,0,0.08)</offset>
                    <flip>true</flip>
                </west>
            </ingestHoldOffsetStanding>
            <ingestHoldUsesTable>false</ingestHoldUsesTable>
            <ingestCommandString>Smoke {0}</ingestCommandString>
            <ingestReportString>Smoking {0}.</ingestReportString>
            <ingestReportStringEat>Consuming {0}.</ingestReportStringEat>
            <useEatingSpeedStat>false</useEatingSpeedStat>
            <chairSearchRadius>0</chairSearchRadius>
            <outcomeDoers>
                <li Class="IngestionOutcomeDoer_GiveHediff">
                    <hediffDef>EssenceSmokeleafHigh</hediffDef>
                    <severity>0.5</severity>
                    <toleranceChemical>EssenceSmokeleaf</toleranceChemical>
                </li>
                <li Class="IngestionOutcomeDoer_OffsetNeed">
                    <need>Rest</need>
                    <offset>0.6</offset>
                </li>
                <li Class="IngestionOutcomeDoer_GiveHediff">
                    <hediffDef>EssenceSmokeleafTolerance</hediffDef>
                    <toleranceChemical>EssenceSmokeleaf</toleranceChemical>
                    <severity>0.030</severity>
                    <divideByBodySize>true</divideByBodySize>
                    <multiplyByGeneToleranceFactors>true</multiplyByGeneToleranceFactors>
                </li>
            </outcomeDoers>
        </ingestible>
        <recipeMaker>
        <recipeUsers>
            <li>CraftingSpot</li>
            <li>DrugLab</li>
        </recipeUsers>
        <workSpeedStat>DrugCookingSpeed</workSpeedStat>
        <workSkill>Cooking</workSkill>
        <soundWorking>Recipe_Drug</soundWorking>
        <displayPriority>1400</displayPriority>
        </recipeMaker>
        <costList>
        <Weazel_Essence>1</Weazel_Essence>
        <SmokeleafLeaves>4</SmokeleafLeaves>
        </costList>
        <comps>
        <li Class="CompProperties_Drug">
            <chemical>EssenceSmokeleaf</chemical>
            <addictiveness>0.010</addictiveness>
            <minToleranceToAddict>0.20</minToleranceToAddict>
            <existingAddictionSeverityOffset>0.06</existingAddictionSeverityOffset>
            <needLevelOffset>0.9</needLevelOffset>
            <listOrder>20</listOrder>
        </li>
        </comps>
    </ThingDef>

    <HediffDef>
        <defName>EssenceSmokeleafHigh</defName>
        <label>에센스 시가에 취함</label>
        <labelNoun>에센스 시가 취기</labelNoun>
        <description>연기를 타고 흘러들어온 에센스가 혈관에 흐르고있습니다. 기묘한 고양감과 집중력이 느껴집니다.</description>
        <hediffClass>Hediff_High</hediffClass>
        <defaultLabelColor>(1,0,0.5)</defaultLabelColor>
        <scenarioCanAdd>true</scenarioCanAdd>
        <maxSeverity>1.0</maxSeverity>
        <isBad>false</isBad>
        <comps>
        <li Class="HediffCompProperties_SeverityPerDay">
            <severityPerDay>-1.0</severityPerDay>
            <showHoursToRecover>true</showHoursToRecover>
        </li>
        </comps>
        <stages>
            <li>
                <capMods>
                    <li>
                        <capacity>Consciousness</capacity>
                        <offset>0.1</offset>
                    </li>
                </capMods>
                <statOffsets>
                    <WorkSpeedGlobal>0.1</WorkSpeedGlobal>
                </statOffsets>
            </li>
        </stages>
    </HediffDef>

    <ThoughtDef>
        <defName>EssenceSmokeleafHigh</defName>
        <workerClass>ThoughtWorker_Hediff</workerClass>
        <hediff>EssenceSmokeleafHigh</hediff>
        <validWhileDespawned>true</validWhileDespawned>
        <developmentalStageFilter>Baby, Child, Adult</developmentalStageFilter>
        <stages>
        <li>
            <label>에센스 시가 고양</label>
            <description>에센스가 혈관을 흐르는 이 느낌, 참을 수 없어.</description>
            <baseMoodEffect>10</baseMoodEffect>
        </li>
        </stages>
    </ThoughtDef>

    <ChemicalDef>
        <defName>EssenceSmokeleaf</defName>
        <label>에센스 시가</label>
        <addictionHediff>SmokeleafAddiction</addictionHediff>
        <toleranceHediff>SmokeleafTolerance</toleranceHediff>
        <onGeneratedAddictedToleranceChance>0.8</onGeneratedAddictedToleranceChance>
        <geneToleranceBuildupFactorResist>0.5</geneToleranceBuildupFactorResist>
        <geneToleranceBuildupFactorImmune>0</geneToleranceBuildupFactorImmune>
    </ChemicalDef>

    <NeedDef ParentName="DrugAddictionNeedBase">
        <defName>Chemical_EssenceSmokeleaf</defName>
        <needClass>Need_Chemical</needClass>
        <label>에센스시가</label>
        <description>에센스 시가로 인한 금단 증상을 피하기 위해, 정기적으로 에센스 시가를 피워줄 필요가 있습니다.</description>
        <listPriority>25</listPriority>
    </NeedDef>

    <HediffDef ParentName="DrugToleranceBase">
        <defName>EssenceSmokeleafTolerance</defName>
        <label>에센스 시가 내성</label>
        <description>에센스 시가에 대한 내성이 쌓인 상태입니다. 이 내성이 심할수록, 같은 효과를 얻기 위해 더 많은 에센스 시가가 필요합니다.</description>
        <comps>
        <li Class="HediffCompProperties_SeverityPerDay">
            <severityPerDay>-0.015</severityPerDay>
        </li>
        <li Class="HediffCompProperties_DrugEffectFactor">
            <chemical>EssenceSmokeleaf</chemical>
        </li>
        </comps>
        <!--
        <hediffGivers>
            <li Class="HediffGiver_RandomDrugEffect">
                <hediff>Carcinoma</hediff>
                <severityToMtbDaysCurve>
                <points>
                    <li>(0.36, 99999)</li>
                    <li>(0.4, 180)</li>
                    <li>(1, 135)</li>
                </points>
                </severityToMtbDaysCurve>
                <partsToAffect>
                <li>Lung</li>
                </partsToAffect>
                <countToAffect>1</countToAffect>
            </li>
        </hediffGivers>
        -->
    </HediffDef>

    <HediffDef ParentName="AddictionBase">
        <defName>EssenceSmokeleafAddiction</defName>
        <label>에센스 시가 의존증</label>
        <description>에센스 시가는 중독성이 낮은편이지만 그럼에도 유용하고, 위험합니다.</description>
        <hediffClass>Hediff_Addiction</hediffClass>
        <chemicalNeed>Chemical_EssenceSmokeleaf</chemicalNeed>
        <comps>
        <li Class="HediffCompProperties_SeverityPerDay">
            <severityPerDay>-0.0333</severityPerDay>
            <showDaysToRecover>true</showDaysToRecover>
        </li>
        </comps>
        <stages>
        <li>
        </li>
        <li>
            <label>withdrawal</label>
            <capMods>
            <li>
                <capacity>Consciousness</capacity>
                <offset>-0.20</offset>
            </li>
            <li>
                <capacity>Moving</capacity>
                <offset>-0.15</offset>
            </li>
            </capMods>
            <mentalStateGivers>
            <li>
                <mentalState>Binging_Food</mentalState>
                <mtbDays>30</mtbDays>
            </li>
            <li>
                <mentalState>Binging_DrugMajor</mentalState>
                <mtbDays>50</mtbDays>
            </li>
            </mentalStateGivers>
        </li>
        </stages>
    </HediffDef>

    <ThoughtDef>
        <defName>EssenceSmokeleafWithdrawal</defName>
        <workerClass>ThoughtWorker_Hediff</workerClass>
        <hediff>EssenceSmokeleafAddiction</hediff>
        <validWhileDespawned>true</validWhileDespawned>
        <developmentalStageFilter>Baby, Child, Adult</developmentalStageFilter>
        <stages>
        <li>
            <visible>false</visible>
        </li>
        <li>
            <label>에센스 시가 중독</label>
            <description>당장 그 빌어먹을 시가 내게 가져와!</description>
            <baseMoodEffect>-20</baseMoodEffect>
        </li>
        </stages>
    </ThoughtDef>
</Defs>